---
interface Props {
    lang?: "en" | "he";
}
const { lang } = Astro.props;
---

<footer>
    {
        lang === "he" ? (
            <p>נבנה באהבה ב<span>חריש, ישראל</span></p>
        ) : lang === "en" ? (
            <p>Built with care in <span>Harish, Israel</span></p>
        ) : (
            <p data-i18n="footer.text">
                Built with care in <span>Harish, Israel</span>
            </p>
        )
    }
</footer>

<style>
    footer {
        text-align: center;
        padding: 40px 0;
        border-top: 1px solid var(--card-border);
        animation: fadeUp 0.8s ease-out 0.4s backwards;
    }

    footer p {
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    footer span {
        color: var(--accent);
    }
</style>
