<style>
    .packages-section {
        margin-bottom: 100px;
        position: relative;
        z-index: 2;
        animation: fadeUp 0.8s ease-out 0.2s backwards;
    }

    .section-label {
        font-size: 1.5rem;
        color: var(--text);
        margin-bottom: 40px;
        font-family: "Fraunces", serif;
        font-weight: 300;
        text-align: center;
    }

    .packages-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 24px;
        align-items: stretch;
    }

    .package-card {
        background: rgba(15, 15, 15, 0.4);
        border: 1px solid var(--card-border);
        border-radius: 16px;
        padding: 32px 24px;
        display: flex;
        flex-direction: column;
        transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
        position: relative;
        overflow: hidden;
    }

    .package-card:hover {
        transform: translateY(-4px);
        border-color: rgba(201, 162, 39, 0.8);
        box-shadow: 0 10px 40px -10px rgba(201, 162, 39, 0.15);
    }

    .glow {
        position: absolute;
        top: 0;
        left: 50%;
        width: 100px;
        height: 1px;
        background: var(--accent);
        transform: translateX(-50%);
        box-shadow: 0 0 20px 2px var(--accent);
        opacity: 0;
        transition: opacity 0.3s ease;
    }

    .package-card:hover .glow {
        opacity: 0.6;
    }

    .package-card h3 {
        font-size: 1.25rem;
        font-weight: 500;
        color: var(--text);
        margin: 0 0 12px 0;
    }

    .package-card:hover h3 {
        color: var(--accent);
    }

    .desc {
        font-size: 0.95rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin-bottom: 24px;
    }

    .features {
        list-style: none;
        padding: 0;
        margin: 0 0 32px 0;
        display: flex;
        flex-direction: column;
        gap: 16px;
    }

    .features li {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        font-size: 0.9rem;
        color: var(--text);
        line-height: 1.4;
    }

    .features svg {
        width: 18px;
        height: 18px;
        flex-shrink: 0;
        color: var(--accent);
        margin-top: 2px;
    }

    .wa-btn {
        margin-top: auto;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 100%;
        padding: 12px 24px;
        background: rgba(201, 162, 39, 0.08);
        color: var(--text);
        border: 1px solid rgba(201, 162, 39, 0.2);
        border-radius: 8px;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        transition: all 0.3s ease;
        text-align: center;
    }

    .package-card:hover .wa-btn {
        background: rgba(201, 162, 39, 0.15);
        border-color: rgba(201, 162, 39, 0.5);
        color: var(--accent);
    }

    .wa-btn:hover {
        background: rgba(201, 162, 39, 0.25) !important;
        transform: translateY(-2px);
    }

    /* RTL spacing boosts for Hebrew */
    [dir="rtl"] .desc,
    [dir="rtl"] .features li {
        line-height: 1.7;
        letter-spacing: 0.2px;
    }

    [dir="rtl"] .wa-btn {
        font-size: 1.05rem; /* slight bump for Hebrew UI text readability */
    }

    @media (max-width: 900px) {
        .packages-grid {
            grid-template-columns: 1fr;
        }
    }
    
    @keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

