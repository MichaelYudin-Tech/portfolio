---
import { Image } from "astro:assets";
import Layout from "../../../layouts/Layout.astro";
import Noise from "../../../components/Noise.astro";
import NoiseReveal from "../../../components/NoiseReveal.astro";
import Orb from "../../../components/Orb.astro";
import Footer from "../../../components/Footer.astro";
import WorkWithMe from "../../../components/WorkWithMe.astro";
import avqbScores from "../../../assets/blog/avqb-pagespeed.png";
import pigumScores from "../../../assets/blog/pigum-yashir-pagespeed.png";

const siteUrl = "https://michaeltech.net";
const slug = "why-astro-not-wordpress";
const canonical = `${siteUrl}/he/blog/${slug}`;
const altLangUrl = `${siteUrl}/blog/${slug}`;
const datePublished = "2026-05-10";
const dateModified = "2026-05-10";

const title =
    "למה אני בונה אתרים עסקיים עם Astro ולא עם WordPress | MichaelTech";
const description =
    "Astro מול WordPress לאתרים עסקיים קטנים. למה עברתי, מה הלקוחות שלי באמת מקבלים, ומתי דווקא וורדפרס היא הבחירה הנכונה.";

const keywords = [
    "אתר עסקי מהיר",
    "אסטרו מול וורדפרס",
    "בניית אתר לעסק קטן",
    "אתר וורדפרס איטי",
    "פיתוח אתרים בישראל",
].join(", ");

const articleJsonLd = {
    "@context": "https://schema.org",
    "@type": "BlogPosting",
    headline: "למה אני בונה אתרים עסקיים עם Astro ולא עם WordPress",
    description,
    image: [`${siteUrl}/og-image.png`],
    datePublished,
    dateModified,
    inLanguage: "he",
    author: {
        "@type": "Person",
        name: "Michael Yudin",
        url: siteUrl,
    },
    publisher: {
        "@type": "Organization",
        name: "MichaelTech",
        url: siteUrl,
        logo: {
            "@type": "ImageObject",
            url: `${siteUrl}/favicon.png`,
        },
    },
    mainEntityOfPage: {
        "@type": "WebPage",
        "@id": canonical,
    },
    keywords,
};

const breadcrumbsJsonLd = {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        {
            "@type": "ListItem",
            position: 1,
            name: "בית",
            item: siteUrl,
        },
        {
            "@type": "ListItem",
            position: 2,
            name: "בלוג",
            item: `${siteUrl}/he/blog`,
        },
        {
            "@type": "ListItem",
            position: 3,
            name: "למה Astro ולא WordPress",
            item: canonical,
        },
    ],
};
---

<Layout
    title={title}
    description={description}
    lang="he"
    altLangUrl={altLangUrl}
    altLangCode="en"
    canonical={canonical}
    type="article"
    publishedTime={datePublished}
    modifiedTime={dateModified}
    author="Michael Yudin"
    keywords={keywords}
>
    <script
        slot="head"
        type="application/ld+json"
        set:html={JSON.stringify(articleJsonLd)}
    />
    <script
        slot="head"
        type="application/ld+json"
        set:html={JSON.stringify(breadcrumbsJsonLd)}
    />

    <Noise />
    <NoiseReveal />
    <Orb />

    <div class="page">
        <nav class="breadcrumbs" aria-label="פירורי לחם">
            <a href="/">בית</a>
            <span aria-hidden="true">/</span>
            <a href="/he/blog">בלוג</a>
            <span aria-hidden="true">/</span>
            <span aria-current="page">למה Astro ולא WordPress</span>
        </nav>

        <article>
            <header class="hero">
                <div class="hero-meta">
                    <span class="tag">פיתוח אתרים</span>
                    <time datetime={datePublished}>10 במאי 2026</time>
                    <span class="dot" aria-hidden="true">·</span>
                    <span>כ-7 דקות קריאה</span>
                </div>
                <h1>
                    למה אני בונה אתרים עסקיים עם <span dir="ltr">Astro</span>
                    ולא עם <span dir="ltr">WordPress</span>
                </h1>
                <p class="lede">
                    רוב העסקים הקטנים בישראל יושבים היום על וורדפרס. גם אני
                    בניתי שם פעם. כאן אני מסביר למה הפסקתי, מה אני בונה
                    במקום, ומה הלקוחות שלי מקבלים בסוף.
                </p>
            </header>

            <div class="prose">
                <p>
                    תיכנסו לכל עסק קטן בישראל ב-2026 ותשאלו על איזו פלטפורמה
                    האתר שלהם רץ. עשרה מתוך עשרה — וורדפרס. לפעמים בעל העסק
                    יודע את זה, לפעמים לא. הוא רק יודע שכל חודש יורדת לו
                    הוראת קבע על "תחזוקה", ושהאתר מרגיש איטי במובייל.
                </p>

                <p>
                    גם אני בניתי הרבה שנים על וורדפרס. זה כלי שמפרנס המון
                    סוכנויות, ויש לזה סיבות. אבל לסוג העבודה שאני לוקח היום —
                    אתרי תדמית של בין חמישה לעשרים עמודים לעסקים שרוצים להיראות
                    מקצועיים ולהופיע בגוגל — הפסקתי לבחור בו. הנה למה.
                </p>

                <h2>מה הבעיה עם וורדפרס לעסק קטן ב-2026</h2>

                <p>
                    וורדפרס היא לא פלטפורמה גרועה. היא מריצה חלק עצום מהאינטרנט,
                    ויש לכך הצדקה אמיתית: בעל עסק לא טכני יכול להיכנס ולעדכן את
                    הבאנר בעמוד הבית בלי להתקשר למפתח. זה כוח אמיתי — אם יש לך
                    צוות תוכן שמעלה פוסט כל יום, או קטלוג מורכב עם אלפי מוצרים.
                </p>

                <p>
                    הבעיה היא שלרוב העסקים הקטנים אין צורך בזה. חברת השכרת
                    פיגומים לא משנה את עמוד המחירים בכל יום שלישי. יבואן לא
                    מנהל מערכת תוכן יומית. מה שהם רוצים זה אתר נקי, מקצועי,
                    שעולה מהר, מופיע בגוגל ולא נופל. ועל וורדפרס, מדי חודש,
                    הם משלמים על יכולות שלא משתמשים בהן:
                </p>

                <ul>
                    <li>
                        <strong>תחזוקת אבטחה.</strong> הליבה של וורדפרס וכל
                        תוסף שמתקינים — כל אחד מהם הוא משטח תקיפה. דילוג של
                        כמה עדכונים והאתר הופך למטרה. רוב הלקוחות מוציאים את
                        זה החוצה, ומשלמים על זה כל חודש.
                    </li>
                    <li>
                        <strong>אינפלציה של תוספים.</strong> אתר תדמית טיפוסי
                        גומר עם 15 עד 30 תוספים, חצי מהם נטענים בכל עמוד. כל
                        אחד מביא איתו עוד CSS ועוד JavaScript, והם מתנגשים.
                    </li>
                    <li>
                        <strong>ביצועים.</strong> וורדפרס בונה כל עמוד בזמן
                        אמת מול מסד נתונים. זה איטי מטבעו. מנסים לכסות על זה
                        עם תוספי מטמון, אבל מטמון הוא פלסטר, לא פתרון.
                    </li>
                    <li>
                        <strong>עלויות סמויות.</strong> אחסון שבאמת מהיר, ערכת
                        עיצוב פרימיום, תוספים בתשלום לטפסים, ל-SEO, לגיבויים —
                        אפשר לסיים שנה ב-1,500 ש"ח לפני שמכרת מוצר אחד.
                    </li>
                </ul>

                <p>
                    שום דבר מזה הוא לא באג של וורדפרס. זה כלי גדול שמשתמשים
                    בו כדי לפצח אגוז.
                </p>

                <h2>מה זה Astro (במונחים של בעל עסק)</h2>

                <p>
                    Astro היא תשתית לבניית אתרים. ההבדל המרכזי בינה לבין
                    וורדפרס הוא <strong>מתי</strong> העבודה נעשית.
                </p>

                <p>
                    תחשבו על וורדפרס כמו מסעדה שמבשלת כל מנה רק כשהיא מוזמנת.
                    לקוח נכנס, המטבח מתחיל לעבוד, האוכל מגיע — איטי, אבל גמיש.
                    Astro דומה יותר למאפייה שהדפיסה את כל המגשים בבוקר וערמה
                    אותם ליד הדלת. כשמישהו נכנס, המגש כבר מוכן. אין שאילתה
                    למסד נתונים, אין מטבח שצריך להתחמם.
                </p>

                <p>
                    הגרסה הטכנית: Astro בונה את האתר פעם אחת, לקבצי HTML
                    סטטיים. ברירת המחדל היא אפס JavaScript — היא מוסיפה רק
                    איפה שבאמת צריך אינטראקטיביות. התוצאה היא אתרים שמקבלים
                    ציוני 90+ ב-PageSpeed Insights של גוגל בלי שום אופטימיזציה
                    מיוחדת, ושלא דורשים מסד נתונים או שרת שדולק כל הזמן.
                </p>

                <p>
                    לאתר תדמית, זה כל התפקיד. להיות מהיר, להיות מאותר, להיראות
                    טוב, לעבוד בכל מקום.
                </p>

                <h2>הסטאק שלי: <span dir="ltr">Astro + Sanity + Tailwind</span></h2>

                <p>
                    Astro לבדה נותנת אתר מהיר. אני משלב אותה עם שני כלים נוספים:
                </p>

                <ul>
                    <li>
                        <strong>Sanity</strong> מנהלת את התוכן. זו מערכת
                        עריכה קטנה ונקייה, שבה הלקוח נכנס ועורך טקסט, מחליף
                        תמונה, מעדכן מחירון — ו-Astro בונה מחדש את האתר
                        אוטומטית ברגע שהוא לוחץ "פרסם". הלקוח מקבל את היתרון
                        של "אני יכול לעדכן לבד" של וורדפרס, בלי וורדפרס.
                    </li>
                    <li>
                        <strong>Tailwind</strong> זו השיטה שאני בונה איתה את
                        העיצוב. היא מאפשרת לי להגיע לעיצוב מדויק בנייד, בטאבלט
                        ובדסקטופ בלי לגרור איתי ערכת עיצוב כבדה. כל אתר יוצא
                        אחיד, רספונסיבי, ומעוצב בדיוק כמו שהמותג צריך.
                    </li>
                </ul>

                <p>
                    Astro היא הדבק. Sanity מחזיקה את הטקסטים. Tailwind מציירת
                    את התמונה. בעל העסק מקבל אתר שעולה מיד, שהוא יכול לערוך
                    בעצמו, ושלא צריך צוות תחזוקה כדי לשמור עליו בחיים.
                </p>

                <h2>תוצאות מעבודה אמיתית מול לקוחות</h2>

                <p>
                    שני פרויקטים אחרונים, שניהם באוויר, שניהם משרתים עסקים
                    קטנים בישראל. הציונים שלמטה הם של PageSpeed Insights
                    במובייל — אותו טסט שגוגל עצמה משתמשת בו כדי למדוד את
                    ה-Core Web Vitals של אתר.
                </p>

                <h3>AVQB — יבואן של מוצרי <span dir="ltr">Voltronic</span> ו-<span dir="ltr">Winmaxx</span></h3>

                <p>
                    AVQB היו צריכים אתר קטלוגי ותדמיתי שייתן להם להיראות
                    אמינים מול סיטונאים. בנוי על Astro:
                </p>

                <figure>
                    <Image
                        src={avqbScores}
                        alt="ציוני PageSpeed Insights במובייל לאתר AVQB: ביצועים 90, נגישות 94, פרקטיקות מומלצות 96, SEO 100."
                        widths={[400, 800]}
                        sizes="(max-width: 700px) 100vw, 700px"
                        loading="lazy"
                    />
                    <figcaption>
                        ציונים במובייל של AVQB: 90 ביצועים · 94 נגישות · 96
                        פרקטיקות · 100 SEO.
                    </figcaption>
                </figure>

                <p>
                    100 מתוך 100 ב-SEO ו-90 בביצועים במובייל זה משהו שרוב
                    אתרי וורדפרס צריכים מעבר אופטימיזציה ייעודי, ועוד תוסף
                    בתשלום או שניים, רק כדי להתקרב אליו.
                </p>

                <h3>פיגום ישיר — השכרת פיגומים ניידים</h3>

                <p>
                    עסק שירות שחי או מת לפי החיפושים המקומיים בגוגל. האתר
                    החדש עלה לאוויר עם מעקב המרות של Google Ads מחובר מהיום
                    הראשון, וייצר ליד ראשון מאיכות בתוך 24 שעות.
                </p>

                <figure>
                    <Image
                        src={pigumScores}
                        alt="ציוני PageSpeed Insights במובייל לאתר פיגום ישיר: ביצועים 99, נגישות 88, פרקטיקות מומלצות 100, SEO 100."
                        widths={[400, 800]}
                        sizes="(max-width: 700px) 100vw, 700px"
                        loading="lazy"
                    />
                    <figcaption>
                        ציונים במובייל של פיגום ישיר: 99 ביצועים · 88 נגישות
                        · 100 פרקטיקות · 100 SEO.
                    </figcaption>
                </figure>

                <p>
                    99 בביצועים במובייל ממקם את האתר באחוזון העליון של
                    הדפים שגוגל מודדת. לעסק שהלקוחות שלו מתקשרים אליו מהכביש
                    בטלפון, זה לא נושא של יוקרה — זה השאלה אם הדף טוען לפני
                    שהם עוברים לתוצאה הבאה.
                </p>

                <p>
                    לשם השוואה: אתרי וורדפרס טיפוסיים של עסקים קטנים שאני
                    בודק מקבלים ציון בין 35 ל-60 בביצועים במובייל, עם
                    First Contentful Paint של בין 3 ל-6 שניות. האתרים שלמעלה
                    יושבים מתחת ל-1.5 שניות, על אותה חומרה, באותה רשת.
                </p>

                <h2>מתי דווקא לא לעבור ל-Astro</h2>

                <p>
                    הייתי משקר אם הייתי אומר ש-Astro מתאימה לכולם. יש מקרים
                    שבהם אני אומר ללקוח להישאר על וורדפרס (או Shopify, או
                    Webflow, תלוי בסיטואציה):
                </p>

                <ul>
                    <li>
                        <strong>מסחר אלקטרוני כבד.</strong> אם צריך WooCommerce
                        עם 10,000 מק"טים, מחירים משתנים לפי וריאציות, וזרם
                        מתמיד של עדכוני מלאי — האקוסיסטם של וורדפרס באמת קשה
                        לנצח בתקציב סביר.
                    </li>
                    <li>
                        <strong>מערך תוכן יומי.</strong> צוות של 20 עורכים
                        שמעלה תוכן, עם היסטוריית גרסאות והרשאות עריכה? וורדפרס
                        נבנתה בדיוק לסוג הארגון הזה.
                    </li>
                    <li>
                        <strong>לוגיקה עסקית שתלויה בתוספים.</strong> אם
                        מערכת ההזמנות, אזור החברים והפורום שלך הם כולם תוספי
                        וורדפרס שמדברים אחד עם השני, להוציא את זה זה לא רידיזיין
                        — זה מעבר פלטפורמה. Astro היא לא התשובה הנכונה שם
                        מבחינת עלות.
                    </li>
                </ul>

                <p>
                    המבחן הכן: כמה פעמים התוכן שלך משתנה, וכמה מורכבת הלוגיקה
                    בצד האחורי. אם התשובה היא "כמה פעמים בחודש" ו"לא במיוחד"
                    — וזה רוב העסקים שאני מדבר איתם — Astro תיתן לך אתר יותר
                    מהיר, יותר זול, יותר בטוח. אם התשובה היא "כל הזמן" ו"מאוד"
                    — אל תשנה את מה שעובד.
                </p>

                <h2>אם האתר וורדפרס שלך איטי ועולה לך כל חודש</h2>

                <p>
                    אם אתה בעל עסק שמשלם כל חודש על תחזוקת וורדפרס, האתר עדיין
                    טוען לאט, ויש לך הרגשה שאתה משלם על מערכת שאתה לא באמת
                    צריך — בוא נדבר. אני בונה אתרים מהירים, מאובטחים, ועם
                    תחזוקה מינימלית לעסקים קטנים. רוב הלקוחות שלי מגיעים אליי
                    בדיוק מהמצב הזה.
                </p>

                <p>
                    אפשר לראות
                    <a href="/projects/kt-rms"> תיק עבודות מורחב של פרויקט אחרון</a>,
                    או לעבור על
                    <a href="/#packages"> חבילות השירות</a>. או פשוט לגלול
                    למטה ולשלוח לי הודעה.
                </p>
            </div>
        </article>

        <WorkWithMe />
        <Footer />
    </div>
</Layout>

<style>
    .page {
        max-width: 760px;
        margin: 0 auto;
        padding: 40px 24px 60px;
        position: relative;
        z-index: 1;
    }

    .breadcrumbs {
        display: flex;
        gap: 8px;
        align-items: center;
        font-size: 0.85rem;
        color: var(--text-muted);
        margin-bottom: 40px;
        flex-wrap: wrap;
    }
    .breadcrumbs a {
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.3s ease;
    }
    .breadcrumbs a:hover {
        color: var(--accent);
    }
    .breadcrumbs [aria-current="page"] {
        color: var(--text);
    }

    .hero {
        margin-bottom: 56px;
        animation: fadeUp 0.8s ease-out;
    }
    .hero-meta {
        display: flex;
        gap: 12px;
        align-items: center;
        flex-wrap: wrap;
        margin-bottom: 24px;
        font-size: 0.85rem;
        color: var(--text-muted);
    }
    .tag {
        font-size: 0.72rem;
        letter-spacing: 0.04em;
        padding: 5px 14px;
        background: rgba(201, 162, 39, 0.12);
        color: var(--accent);
        border-radius: 18px;
        font-weight: 500;
    }
    .dot {
        color: var(--text-muted);
        opacity: 0.5;
    }

    h1 {
        font-family: "Fraunces", serif;
        font-size: clamp(1.85rem, 5.5vw, 2.85rem);
        font-weight: 300;
        letter-spacing: -0.005em;
        line-height: 1.3;
        color: var(--text);
        margin-bottom: 20px;
